<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <hasActivationRequired>false</hasActivationRequired>
    <label>Similar Insights Semantic User</label>
    <description>Grants access to the intent classification fields and Apex classes shipped by the Similar Insights: Semantic Matching package.</description>
    <classAccesses>
        <apexClass>IntentClassifier</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>IntentClassifierQueueable</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>IntentInsightAnalyzer</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>IntentPatternAlertController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <fieldPermissions>
        <editable>true</editable>
        <field>MedicalInsight.Intent_Classification__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>MedicalInsight.Intent_Confidence__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>MedicalInsight.Intent_Rationale__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>MedicalInsight.Intent_Classified_At__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>MedicalInsight.Intent_Subtopics__c</field>
        <readable>true</readable>
    </fieldPermissions>
</PermissionSet>
